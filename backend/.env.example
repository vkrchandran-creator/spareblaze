# Server
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Database (get connection string from Supabase / Neon)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/spareblaze

# JWT
JWT_SECRET=replace-with-256-bit-random-secret
JWT_EXPIRES_IN=7d

# Payment — PayU (get from PayU Merchant Dashboard)
PAYU_MERCHANT_KEY=
PAYU_MERCHANT_SALT=
# Backend public URL (used to build PayU surl/furl callback URLs)
BACKEND_URL=https://your-backend-url.com

# Email — SMTP (works with Gmail, Zoho, SendGrid SMTP, Mailgun, etc.)
# Leave blank to disable order confirmation emails (payment flow is unaffected).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=SpareBlaze <your-email@gmail.com>

# Image Storage — Cloudinary
CLOUDINARY_URL=
