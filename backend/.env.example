# Server
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Database (get connection string from Supabase / Neon)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/spareblaze

# JWT
JWT_SECRET=replace-with-256-bit-random-secret
JWT_EXPIRES_IN=7d

# Payment — Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Email — SendGrid or Resend
SENDGRID_API_KEY=

# Image Storage — Cloudinary
CLOUDINARY_URL=
